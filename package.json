    "catalog:check:cj": "node --env-file=.env.local scripts/catalog-check.mjs --cj",
    "catalog:audit": "node --env-file=.env.local scripts/audit-catalog-cj.mjs",
    "catalog:integrity": "node scripts/catalog-integrity-gate.mjs",
    "catalog:audit-images": "node scripts/audit-live-product-images.mjs",
    "catalog:verify": "node scripts/catalog-check.mjs && node scripts/audit-live-product-images.mjs && node scripts/catalog-integrity-gate.mjs",

    "catalog:report": "node scripts/generate-verified-catalog-report.mjs",
    "catalog:expand:tech": "node --env-file=.env.local scripts/expand-tech-catalog.mjs",
    "catalog:expand:home-wellness": "node --env-file=.env.local scripts/expand-home-wellness-catalog.mjs",
    "catalog:duplicates": "node scripts/find-duplicate-products.mjs",
    "catalog:audit-prices": "node --env-file=.env.local scripts/audit-variant-pricing.mjs",
    "catalog:sync-defaults": "node scripts/sync-default-variant-to-products.mjs --write",
    "store:audit": "node scripts/store-financial-audit.mjs",
    "tiktok:ads": "node scripts/record-tiktok-ad.mjs all",
    "tiktok:ads:batch2": "node scripts/record-tiktok-ad.mjs batch2",
    "tiktok:ads:pet": "node scripts/record-tiktok-ad.mjs pet",
    "tiktok:ads:wellness": "node scripts/record-tiktok-ad.mjs wellness",
    "tiktok:ads:tech": "node scripts/record-tiktok-ad.mjs tech",
    "tiktok:ads:home": "node scripts/record-tiktok-ad.mjs home",
    "tiktok:ads:walk-kit": "node scripts/record-tiktok-ad.mjs pet-walk-kit",
    "social:config": "node scripts/generate-social-ads-config.mjs",
    "social:feed": "node scripts/export-social-feed-images.mjs",
    "social:videos": "node scripts/record-social-videos.mjs",
    "social:pack": "node scripts/build-social-pack.mjs",
    "social:playbook": "node scripts/export-content-playbook.mjs",
    "social:organic": "node --env-file=.env.local scripts/social-organic-daily.mjs",
    "social:organic:force": "node --env-file=.env.local scripts/social-organic-daily.mjs --force",
    "social:organic:dry": "node --env-file=.env.local scripts/social-organic-daily.mjs --dry-run",
    "social:organic:install": "powershell -ExecutionPolicy Bypass -File scripts/setup-social-organic.ps1",
    "social:video:one": "node scripts/record-single-social-video.mjs",
    "ads:autopilot": "node --env-file=.env.local scripts/meta-ads-autopilot.mjs",
    "ads:review": "node --env-file=.env.local scripts/meta-ads-review.mjs",
    "ads:run": "node --env-file=.env.local scripts/run-ad-autopilot.mjs",
    "ads:watch": "node --env-file=.env.local scripts/ads-auto-watch.mjs",
    "ads:jarvis": "node --env-file=.env.local scripts/ads-jarvis.mjs",
    "ads:optimize": "node --env-file=.env.local scripts/ads-auto-optimize.mjs",
    "ads:watch:install": "powershell -ExecutionPolicy Bypass -File scripts/setup-ad-auto-watch.ps1",
    "ads:daily-report": "node --env-file=.env.local scripts/ads-daily-report.mjs",
    "ads:daily-report:install": "powershell -ExecutionPolicy Bypass -File scripts/setup-daily-report.ps1",
    "ads:video-publish": "node --env-file=.env.local scripts/meta-ads-video-publish.mjs",
    "ads:meta-recs": "node --env-file=.env.local scripts/meta-recommendations-sync.mjs",
    "ads:placement-fix": "node --env-file=.env.local scripts/ads-placement-fix.mjs",
    "ads:llm-test": "node --env-file=.env.local scripts/test-llm-advisor.mjs",
    "ads:test-pack": "node --env-file=.env.local scripts/test-ai-marketer-pack.mjs",
    "ads:dashboard": "node --env-file=.env.local scripts/ads-dashboard-server.mjs",
    "alexa:check": "node --env-file=.env.local scripts/verify-alexa-pc.mjs",
    "paypal:verify": "node --env-file=.env.local scripts/verify-paypal-live.mjs",
    "ads:dashboard:watchdog": "node --env-file=.env.local scripts/ads-dashboard-watchdog.mjs",
    "ads:dashboard:install": "powershell -ExecutionPolicy Bypass -File scripts/setup-dashboard-watchdog.ps1",
    "ads:app": "powershell -ExecutionPolicy Bypass -File scripts/trove-autopilot-app.ps1",
    "ads:app:install": "powershell -ExecutionPolicy Bypass -File scripts/install-trove-autopilot-desktop.ps1",
    "telegram:setup": "node scripts/setup-telegram.mjs",
    "env:sync": "node scripts/sync-env-from-vercel.mjs",
    "health:check": "node --env-file=.env.local scripts/trove-health-check.mjs",
    "health:sync": "node --env-file=.env.local scripts/trove-health-check.mjs --sync",
    "deploy": "vercel --prod --yes",
    "deploy:preview": "vercel --yes"
  },
  "dependencies": {
    "@paypal/react-paypal-js": "^10.0.0",
    "@upstash/redis": "^1.38.0",
    "next": "16.2.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "resend": "^6.14.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "playwright": "^1.52.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vercel": "^54.14.2"
  }
}
