{
  "name": "techdrop-us",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "margins": "node scripts/margins.mjs",
    "catalog:check": "node scripts/catalog-check.mjs",
    "catalog:check:cj": "node --env-file=.env.local scripts/catalog-check.mjs --cj",
    "catalog:duplicates": "node scripts/find-duplicate-products.mjs",
