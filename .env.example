# Site URL
NEXT_PUBLIC_SITE_URL=https://trove-us.com

# Meta (Facebook) Pixel — Events Manager → Data Sources → your pixel ID
# https://business.facebook.com/events_manager
NEXT_PUBLIC_META_PIXEL_ID=

# Owner PIN for /admin, /analytics and /launch (server-only — never use NEXT_PUBLIC_)
OWNER_PIN=

# ─── PayPal ───
# Create app: https://developer.paypal.com/dashboard/applications/sandbox
NEXT_PUBLIC_PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_MODE=sandbox

# ─── CJ Dropshipping ───
CJ_API_KEY=
CJ_PAY_TYPE=3
CJ_FROM_COUNTRY=US
CJ_STORE_NAME=Trove
# Optional: preferred shipping method name from CJ freight API
CJ_LOGISTIC_NAME=
# Your CJ openId — used to verify webhook signatures (from getAccessToken response)
CJ_OPEN_ID=

# ─── Order storage (Upstash Redis via Vercel Integration) ───
# Vercel → Integrations → Upstash for Redis → connect to trove-us
# Creates KV_REST_API_* or UPSTASH_REDIS_REST_* automatically
KV_REST_API_URL=
KV_REST_API_TOKEN=
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# ─── Transactional email (Resend) ───
# https://resend.com — verify domain for production (trove-us.com)
RESEND_API_KEY=
EMAIL_FROM=Trove <orders@trove-us.com>

# ─── Sale & return alerts (Telegram and/or WhatsApp) ───
# Telegram (recommended): talk to @BotFather → /newbot → copy token
# Chat ID: message your bot, then open https://api.telegram.org/bot<TOKEN>/getUpdates
# Alerts: 🛒 new sale · ↩️ return / purchase problem
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# WhatsApp optional (CallMeBot — free for personal use):
# https://www.callmebot.com/blog/free-api-whatsapp-messages/
# Phone with country code, no + (e.g. 5511999999999)
WHATSAPP_NOTIFY_PHONE=
WHATSAPP_CALLMEBOT_APIKEY=
