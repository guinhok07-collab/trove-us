# Site URL (used for sitemap and Open Graph)
NEXT_PUBLIC_SITE_URL=https://trove-us.vercel.app

# Optional: PIN to protect /analytics and /launch dashboards
NEXT_PUBLIC_ANALYTICS_PIN=

# ─── CJ Dropshipping (automatic orders) ───
# Get API key: CJ dashboard → Authorization → API → Generate
CJ_API_KEY=

# Pay type: 2 = auto-pay from CJ wallet (recommended), 3 = create order only
CJ_PAY_TYPE=2

# Ship from US warehouse
CJ_FROM_COUNTRY=US

# Store name in CJ (must match API store in CJ if configured)
CJ_STORE_NAME=Trove

# Optional: force a specific carrier name from CJ freight calculation
# CJ_LOGISTIC_NAME=USPS+

# Payment — add when ready to collect from customers
# NEXT_PUBLIC_PAYPAL_CLIENT_ID=
# STRIPE_SECRET_KEY=
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Email — order confirmations
# RESEND_API_KEY=
